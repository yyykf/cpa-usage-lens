# CPA Usage Lens — 环境变量模板。复制为 .env 后填入真实值（.env 不进 git）。

# ---- CPA 数据源 ----
CPA_BASE_URL=https://your-cpa-host.example.com
CPA_MANAGEMENT_KEY=your-cpa-management-secret-key

# ---- Supabase Postgres（pooler / session mode 5432，从 Dashboard → Connect → Session pooler 复制）----
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# ---- Dashboard 登录密码（部署前改成强密码）----
DASHBOARD_PASSWORD=change-me-to-a-strong-password

# ---- 鉴权 token 签名密钥（用 `openssl rand -hex 32` 生成）----
AUTH_TOKEN_SECRET=run-openssl-rand-hex-32

# ---- 采集器 ----
COLLECTOR_POLL_INTERVAL_SECONDS=3
COLLECTOR_BATCH_SIZE=200

# ---- 保留 / 时区 / 聚合（"天"按此时区界定）----
HOT_RETENTION_DAYS=7
TIMEZONE=Asia/Shanghai
ROLLUP_INTERVAL_SECONDS=60

# ---- 服务端口 ----
BACKEND_PORT=8080
